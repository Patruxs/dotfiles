{{- $gitName := "CI User" -}}
{{- $gitEmail := "ci@example.com" -}}
{{- if not (env "CI") -}}
{{-   $gitName = promptStringOnce . "git.name" "Git user.name" "" -}}
{{-   $gitEmail = promptStringOnce . "git.email" "Git user.email" "" -}}
{{- end -}}
encryption = "gpg"
mode = "symlink"

[gpg]
    recipient = "0E923D7CC07C7873C6C4D0F35BC1E5D2E24B1DC9"
    args = ["--quiet"]

[data]
    dotfiles_repo_https = "https://github.com/Patruxs/dotfiles.git"
    dotfiles_repo_ssh = "git@github.com:Patruxs/dotfiles.git"
    dotfiles_owner = "Patruxs"

[data.git]
    name = {{ $gitName | quote }}
    email = {{ $gitEmail | quote }}
