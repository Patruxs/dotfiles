#!/usr/bin/env bash
{{ template "script_helpers.sh.tmpl" . }}

if [ "{{ .chezmoi.os }}" != "linux" ]; then
  exit 0
fi

if ! have flatpak; then
  log "flatpak is not installed; install it with your package manager first"
  exit 0
fi

confirm_or_skip "Install curated Flatpak GUI apps?" || exit 0

if ! flatpak remote-list | awk '{print $1}' | grep -qx flathub; then
  flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

apps=({{- range .packages.flatpak.linux }} "{{ . }}"{{- end }})
for app in "${apps[@]}"; do
  if flatpak info "$app" >/dev/null 2>&1; then
    log "already installed: $app"
    continue
  fi
  flatpak install -y flathub "$app" || log "failed to install flatpak: $app"
done
