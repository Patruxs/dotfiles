#!/usr/bin/env bash
{{ template "script_helpers.sh.tmpl" . }}

if [ "{{ .chezmoi.os }}" = "windows" ]; then
  log "use bootstrap.ps1 for Windows runtime setup"
  exit 0
fi

confirm_or_skip "Install or update mise runtimes?" || exit 0

if ! have mise; then
  log "mise is missing; install system packages first"
  exit 0
fi

mise install

if ! have pipx && have uv; then
  log "installing pipx via uv"
  uv tool install pipx || true
fi

log "mise runtimes configured"
