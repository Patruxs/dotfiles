#!/usr/bin/env bash
{{ template "script_helpers.sh.tmpl" . }}

repo_root="{{ .chezmoi.sourceDir }}"
os="{{ .chezmoi.os }}"

detect_linux_family() {
  if [ -r /etc/os-release ]; then
    . /etc/os-release
    case "${ID_LIKE:-$ID}" in
      *fedora*|*rhel*|*centos*|*nobara*) echo fedora ;;
      *debian*|*ubuntu*) echo debian ;;
      *arch*) echo arch ;;
      *) echo unknown ;;
    esac
  else
    echo unknown
  fi
}

install_dnf() {
  local packages=({{- range .packages.system.fedora }} "{{ . }}"{{- end }})
  local available=()
  for pkg in "${packages[@]}"; do
    if dnf -q info "$pkg" >/dev/null 2>&1; then
      available+=("$pkg")
    else
      log "dnf package not available: $pkg"
    fi
  done
  [ ${#available[@]} -gt 0 ] || return 0
  log "dnf packages: ${available[*]}"
  confirm_or_skip "Install Fedora packages?" || return 0
  sudo dnf install -y "${available[@]}"
}

install_apt() {
  local packages=({{- range .packages.system.debian }} "{{ . }}"{{- end }})
  local available=()
  sudo apt-get update -y
  for pkg in "${packages[@]}"; do
    if apt-cache show "$pkg" >/dev/null 2>&1; then
      available+=("$pkg")
    else
      log "apt package not available: $pkg"
    fi
  done
  [ ${#available[@]} -gt 0 ] || return 0
  log "apt packages: ${available[*]}"
  confirm_or_skip "Install Debian/Ubuntu packages?" || return 0
  sudo apt-get install -y "${available[@]}"
}

install_pacman() {
  local packages=({{- range .packages.system.arch }} "{{ . }}"{{- end }})
  local available=()
  for pkg in "${packages[@]}"; do
    if pacman -Si "$pkg" >/dev/null 2>&1; then
      available+=("$pkg")
    else
      log "pacman package not available: $pkg"
    fi
  done
  [ ${#available[@]} -gt 0 ] || return 0
  log "pacman packages: ${available[*]}"
  confirm_or_skip "Install Arch packages?" || return 0
  sudo pacman -S --needed --noconfirm "${available[@]}"
}

install_brew_bundle() {
  if ! have brew; then
    confirm_or_skip "Install Homebrew?" || return 0
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  log "brew bundle file: $repo_root/packages/Brewfile"
  confirm_or_skip "Install macOS packages with Homebrew?" || return 0
  brew bundle --file="$repo_root/packages/Brewfile"
}

case "$os" in
  linux)
    case "$(detect_linux_family)" in
      fedora) install_dnf ;;
      debian) install_apt ;;
      arch) install_pacman ;;
      *) log "unsupported Linux family; install packages manually" ;;
    esac
    ;;
  darwin)
    install_brew_bundle
    ;;
  windows)
    log "use bootstrap.ps1 for winget package installation"
    ;;
esac
